# Turso database (required on Vercel, optional for local dev)
# Get these from https://turso.tech after creating a database.
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Without these set, the app falls back to a local file: data.db
# which works fine for local development.
